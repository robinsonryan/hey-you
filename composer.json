{
    "name": "robinsonryan/hey-you",
    "description": "A Laravel package",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Ryan Robinson",
            "email": "ryan@example.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "RobinsonRyan\\HeyYou\\": "src/",
            "RobinsonRyan\\HeyYou\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RobinsonRyan\\HeyYou\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "RobinsonRyan\\HeyYou\\HeyYouServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "pest",
        "test:coverage": "pest --coverage",
        "lint": "pint",
        "lint:check": "pint --test",
        "analyze": "phpstan analyse",
        "refactor": "rector process",
        "refactor:check": "rector process --dry-run",
        "quality": [
            "@lint:check",
            "@analyze",
            "@test"
        ]
    }
}
